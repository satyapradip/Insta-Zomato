# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in your real values.
# This file is safe to commit. .env should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/insta-zomato

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long, random string — minimum 32 characters
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Razorpay (Phase 8 — Payments) ────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── SMTP — Email (Phase 12 — Notifications) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Insta-Zomato <no-reply@insta-zomato.com>"

# ── Redis (Phase 15 — Caching) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Google Maps (Phase 9 — Location) ──────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
